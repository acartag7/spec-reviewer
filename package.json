{
  "name": "spec-reviewer",
  "version": "0.1.0",
  "description": "Local-first Markdown spec reviewer for source-anchored agent feedback.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "keywords": [
    "markdown",
    "review",
    "specs",
    "local-first",
    "agent-feedback"
  ],
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.32.0",
    "bun": ">=1.3.6"
  },
  "bin": {
    "spec-reviewer": "bin/spec-reviewer.js"
  },
  "files": [
    "build/",
    "bin/",
    "dist/",
    "docs/",
    "CONTRIBUTING.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "pnpm run check:syntax && pnpm run check:lines && pnpm run test",
    "check:lines": "node --no-warnings src/dev/check-line-limits.ts",
    "check:syntax": "find src test \\( -name '*.ts' -o -name '*.js' \\) -print0 | xargs -0 -n1 node --check && tsc --noEmit",
    "build": "pnpm run build:server && vite build --config web/vite.config.ts && tsc --noEmit",
    "build:binary": "pnpm run build && bun build --compile binary/spec-reviewer.ts --outfile build/spec-reviewer",
    "build:server": "node -e \"require('node:fs').rmSync('build',{recursive:true,force:true})\" && tsc -p tsconfig.server.json",
    "binary:smoke": "node scripts/binary-smoke.js",
    "dev": "concurrently -k -n api,web \"node --no-warnings src/server.ts\" \"vite --config web/vite.config.ts --host 127.0.0.1\"",
    "start": "node --no-warnings src/server.ts",
    "test": "node --no-warnings --test test/*.test.ts && vitest run --config web/vite.config.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.5",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query": "5.96.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dompurify": "3.4.7",
    "lucide-react": "1.7.0",
    "marked": "18.0.4",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "7.15.0",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "jsdom": "29.0.1",
    "shadcn": "4.1.2",
    "typescript": "6.0.3",
    "vite": "8.0.5",
    "vitest": "3.2.4"
  }
}
